@using System.Diagnostics
@using System.Runtime.InteropServices
@using System.Text
@using System.Runtime.InteropServices.JavaScript;

<input @ref="_virtualKeyboard" class="virtual-keyboard" type="password" autocomplete="off" />

<div class="display-wrapper @($"{_windowState}".ToLower())" 
    @onmousemove="@(() => SetControlMode(ControlMode.Mouse))"
    @ontouchstart="@(() => SetControlMode(ControlMode.Touch))">
    <div class="title-bar p-2">
        <div style="align-self: center; margin-left: 10px;">
            <MudText Typo="Typo.h6" Color="MudBlazor.Color.Primary">
                @(Session?.Device?.Name)
            </MudText>
        </div>
        <div style="overflow-x: auto; overflow-y: visible;">
            @if (_windowState != WindowState.Minimized)
            {
                <MudMenu Variant="Variant.Outlined" StartIcon="@(Icons.Material.Filled.FitScreen)" Label="View" PopoverClass="z9001">
                    <MudMenuItem Icon="@(Icons.Material.Filled.FitScreen)"
                                 IconColor="@(_viewMode == ViewMode.Fit ? Color.Success : Color.Default)"
                                 OnClick="@(() => _viewMode = ViewMode.Fit)">
                        Fit
                    </MudMenuItem>
                    <MudMenuItem Icon="@(Icons.Material.Filled.OpenInFull)"
                                 IconColor="@(_viewMode == ViewMode.Stretch ? Color.Success : Color.Default)"
                                 OnClick="@(() => _viewMode = ViewMode.Stretch)">
                        Stretch
                    </MudMenuItem>
                    <MudMenuItem Icon="@(Icons.Material.Filled.Fullscreen)"
                                 IconColor="@(_viewMode == ViewMode.Original ? Color.Success : Color.Default)"
                                 OnClick="@(() => _viewMode = ViewMode.Original)">
                        Original
                    </MudMenuItem>
                </MudMenu>
                <MudMenu Variant="Variant.Outlined" StartIcon="@(Icons.Material.Filled.ScreenshotMonitor)" Label="Monitor" PopoverClass="z9001">
                </MudMenu>

                @if (_controlMode == ControlMode.Touch)
                {
                    <MudButton Variant="Variant.Outlined" StartIcon="@(Icons.Material.Filled.Keyboard)" OnClick="InvokeKeyboard">
                        Keyboard
                    </MudButton>
                }
            }
        </div>
        <div class="header-download-column">
            @if (_downloadProgress > 0 && _downloadProgress < 1)
            {
                <div>
                    <MudText Typo="Typo.subtitle1" Color="MudBlazor.Color.Info">
                        Downloading On Agent:
                    </MudText>
                </div>

                <div>
                    <MudProgressLinear Min="0" Max="1" Value="_downloadProgress" Color="MudBlazor.Color.Tertiary" />
                </div>
            }
        </div>
        <div class="text-end" style="white-space: nowrap">
            @if (_windowState != WindowState.Minimized)
            {
                <MudTooltip Text="Minimize">
                    <MudIconButton Icon="@(Icons.Material.Filled.Minimize)"
                               Class="mr-2"
                               OnClick="@(() => SetWindowState(WindowState.Minimized))" />
                </MudTooltip>
            }

            @if (_windowState != WindowState.Restored)
            {
                <MudTooltip Text="Restore">
                    <MudIconButton Icon="@(Icons.Material.Filled.FullscreenExit)"
                               Class="mr-2"
                               OnClick="@(() => SetWindowState(WindowState.Restored))" />
                </MudTooltip>
            }

            @if (_windowState != WindowState.Maximized)
            {
                <MudTooltip Text="Maximize">
                    <MudIconButton Icon="@(Icons.Material.Filled.Fullscreen)"
                               Class="mr-2"
                               OnClick="@(() => SetWindowState(WindowState.Maximized))" />
                </MudTooltip>
            }

            <MudTooltip Text="Close">
                <MudIconButton Icon="@(Icons.Material.Filled.Close)"
                               OnClick="Close" />
            </MudTooltip>
        </div>
    </div>
    <div class="content-area"
        @ontouchstart="OnTouchStart"
        @ontouchmove="OnTouchMove"
        @ontouchcancel="OnTouchCancel"
        @ontouchend="OnTouchEnd">

        <video id="@_videoId"
               @ref="_videoRef"
               class="@($"{_viewMode.ToString().ToLower()} {_windowState.ToString().ToLower()} remote-screen")"
               style="transform: @(VideoTransform);"/>

        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <div class="text-center mt-10" style="position: absolute; width: 100%; height: 100%">
                <MudText Typo="Typo.h4" Color="MudBlazor.Color.Info" Align="Align.Center" GutterBottom>
                @(_statusMessage)
                </MudText>

                @if (_statusProgress > 0)
                {
                    <MudProgressCircular Min="0" Max="1" Value="_statusProgress" Color="MudBlazor.Color.Info" Size="MudBlazor.Size.Large" />
                }
                else
                {
                    <MudProgressCircular Indeterminate Color="MudBlazor.Color.Info" Size="MudBlazor.Size.Large" />
                }
            </div>
        }
    </div>
</div>