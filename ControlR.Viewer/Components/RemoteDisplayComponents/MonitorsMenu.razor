<MudMenu Variant="Variant.Outlined" StartIcon="@(Icons.Material.Filled.ScreenshotMonitor)" Label="Monitor" PopoverClass="z9001">
    @foreach (var display in Displays)
    {
        <MudMenuItem OnClick="@(() => SelectDisplay(display))">
            <MudText Color="@(display == SelectedDisplay ? Color.Success : Color.Default)">
                @(display.Name)
            </MudText>
        </MudMenuItem>
    }
</MudMenu>

@code {

    [Parameter]
    public Display[] Displays { get; set; } = Array.Empty<Display>();

    [Parameter]
    public Display? SelectedDisplay { get; set; }

    [Parameter]
    public EventCallback<Display> OnDisplaySelected { get; set; }


    private async Task SelectDisplay(Display display)
    {
        await OnDisplaySelected.InvokeAsync(display);
    }
}
